{
    "manifest_version": 2,
    "name": "ThemeGroups",
    "version": "0.2.0",
    "description": "Organize your browser themes into groups.",

    "icons": {
        "16": "icons/v2/icon-16.png",
        "32": "icons/v2/icon-32.png",
        "48": "icons/v2/icon-48.png",
        "128": "icons/v2/icon-128.png"
    },

    "permissions": [
        "management",
        "storage"
    ],

    "background": {
        "scripts": ["background.js"],
        "persistent": false
    },

    "browser_action": {
        "default_icon": {
            "16": "icons/v2/icon-16.png",
            "32": "icons/v2/icon-32.png"
        },
        "default_title": "ThemeGroups",
        "default_popup": "popup/popup.html"
    }

}