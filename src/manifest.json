{
    "manifest_version": 2,
    "name": "ThemeGroups",
    "version": "0.3.0",
    "description": "Organize your browser themes into groups.",

    "icons": {
        "32": "icons/theme-groups-32.png"
    },

    "permissions": [
        "management",
        "storage"
    ],

    "background": {
        "scripts": ["background.js"],
        "persistent": true
    },

    "browser_action": {
        "default_icon": "icons/theme-groups-32.png",
        "default_title": "ThemeGroups",
        "default_popup": "popup/popup.html"
    }

}